# =============================================================================
# NovoProtein AI — Environment Variables
# Copy this file to .env and fill in your values
# =============================================================================

# ─── Authentication ──────────────────────────────────────────────────────────
# Secret key for signing JWT tokens (auto-generated if not set, but MUST be
# set in production for token persistence across restarts)
JWT_SECRET_KEY=

# ─── LLM Providers (Required) ───────────────────────────────────────────────
# OpenRouter API key — used for code generation and agent reasoning
OPENROUTER_API_KEY=

# OpenAI API key — backup LLM access
OPENAI_API_KEY=

# ─── NVIDIA Cloud (Required for protein tools) ──────────────────────────────
# Shared API key for NVIDIA Cloud Functions (AlphaFold2, RFdiffusion, ProteinMPNN, etc.)
NVCF_RUN_KEY=

# ─── Vector Database (Required for RAG) ─────────────────────────────────────
PINECONE_API_KEY=

# ─── AF2Bind ────────────────────────────────────────────────────────────────
AF2BIND_API_URL=http://localhost:8000
AF2BIND_API_KEY=

# ─── Application ────────────────────────────────────────────────────────────
# CORS allowed origins (comma-separated, default: *)
APP_ORIGIN=*

# SQLite database path (default: server/novoprotein.db)
# DATABASE_PATH=server/novoprotein.db

# Debug mode — bypasses rate limiting for localhost (default: 0)
# DEBUG_API=0

# AI logging — set to 0 to disable (default: 1)
# LOG_AI=1

# ─── NVIDIA Endpoints (Optional overrides) ──────────────────────────────────
# NIMS_URL=https://health.api.nvidia.com/v1/biology/deepmind/alphafold2
# RFDIFFUSION_URL=https://health.api.nvidia.com/v1/biology/ipd/rfdiffusion/generate
# ALPHAFOLD3_URL=https://health.api.nvidia.com/v1/biology/openfold/openfold3/predict
# OPENFOLD2_URL=
# PROTEINMPNN_URL=

# ─── NVIDIA Tuning (Optional) ───────────────────────────────────────────────
# POLL_INTERVAL=30
# NIMS_MAX_POLLS=0
# NIMS_REQUEST_TIMEOUT=180
# NIMS_POST_RETRIES=3
# PROTEINMPNN_MAX_WAIT_SECONDS=1800
# DIFFDOCK_TIMEOUT=600
# OPENFOLD2_TIMEOUT=600

# ─── LLM Model Overrides (Optional) ─────────────────────────────────────────
# CLAUDE_CODE_MODEL=claude-3-5-sonnet-20241022
# CLAUDE_CHAT_MODEL=claude-3-5-sonnet-20241022

# ─── LangSmith Tracing (Optional) ───────────────────────────────────────────
# LANGCHAIN_TRACING_V2=false
# LANGCHAIN_API_KEY=
# LANGCHAIN_PROJECT=novoprotein-agent
