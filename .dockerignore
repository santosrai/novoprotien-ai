__tests__/
server/__tests__/
tests/

# Test outputs
test-results/
playwright-report/
coverage/

# Documentation
*.md
!README.md

# Environment files (secrets — use env_file or secrets manager)
.env
.env.local
.env.*.local

# OS files
.DS_Store
Thumbs.db

