# Dependencies (rebuilt in container)
node_modules/
.venv/
venv/

# Build output (rebuilt in container)
dist/

# Database files (use volumes)
*.db
*.db-journal
*.db-wal

# Python cache
__pycache__/
*.py[cod]
*.pyo
.pytest_cache/
.mypy_cache/
htmlcov/
.coverage

